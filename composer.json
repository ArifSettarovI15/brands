{
    "name": "tigereng/brands",
    "description": "TigerWeb Brands module",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Arif Settarov",
            "email": "arif.settarov@mail.ru"
        }
    ],
    "require": {
        "php": ">=7.4.0"
    },
    "autoload": {
        "classmap": ["src"]
    },
    "scripts": {
        "post-install-cmd": [
            "mkdir libraries",
            "cp -r vendor/tigerweb/brands/ libraries/brands"
        ],
        "post-update-cmd": [
            "mkdir libraries",
            "cp -r vendor/tigerweb/brands/ libraries/brands"
        ],
        "post-package-install": [
            "mkdir libraries",
            "cp -r vendor/tigereng/brands/ libraries/brands"
        ]
    }
}
